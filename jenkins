pipeline {
    agent any  // Runs on any available agent/node

    stages {
        stage('Clone') {
            steps {
                git branch: 'main',
                echo 'Cloning from Git...'
                git url: 'https://github.com/srikrishna206/jenkins.git'
            }
        }

        stage('Build') {
            steps {
                echo 'Building the project...'
                sh 'echo "Simulating build..."'
            }
        }

        stage('Deploy') {
            steps {
                echo 'Deploying the project...'
                sh 'echo "Simulating deploy..."'
            }
        }
    }

    post {
        success {
            echo 'Pipeline completed successfully!'
        }
        failure {
            echo 'Pipeline failed.'
        }
    }
}

